{
  "name": "@ddb/mcp-server",
  "version": "0.1.0",
  "description": "DarbotDB MCP server with interactive Apps for adaptive cards, graph exploration, and memory recall",
  "type": "module",
  "scripts": {
    "build": "node scripts/build-views.mjs && tsc",
    "build:views": "node scripts/build-views.mjs",
    "serve": "npx tsx server.ts",
    "serve:stdio": "npx tsx server.ts --stdio"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.0.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.0",
    "tsx": "^4.0.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.0"
  }
}
